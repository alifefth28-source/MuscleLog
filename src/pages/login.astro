---
import BaseLayout from "@/layouts/BaseLayout.astro";
Astro.cookies.delete("ml_token", { path: "/" });
---

<BaseLayout title="MuscleLog — Login">
  <div class="min-h-[100dvh] flex flex-col items-center justify-center px-6 relative overflow-hidden">

    <!-- Decorative blurred orbs -->
    <div class="absolute top-[-20%] left-[-10%] w-[400px] h-[400px] rounded-full opacity-30" style="background: radial-gradient(circle, rgba(59,130,246,0.4), transparent 70%);"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[300px] h-[300px] rounded-full opacity-20" style="background: radial-gradient(circle, rgba(59,130,246,0.3), transparent 70%);"></div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-sm">

      <!-- Logo + Brand -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-4 glow-accent" style="background: rgba(59,130,246,0.15); border: 0.5px solid rgba(59,130,246,0.3);">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6.5 6.5h11"/><path d="M6.5 17.5h11"/><path d="M6 2L6 22"/><path d="M18 2L18 22"/><path d="M3 6h3"/><path d="M3 18h3"/><path d="M18 6h3"/><path d="M18 18h3"/><path d="M12 2v20"/>
          </svg>
        </div>
        <h1 class="text-3xl font-extrabold tracking-tight text-white">MuscleLog</h1>
        <p class="text-ml-muted text-sm mt-1.5">Catat, analisis, tingkatkan performa</p>
      </div>

      <!-- Feature pills -->
      <div class="flex justify-center gap-2 mb-8">
        <span class="glass text-[11px] text-ml-accent-light px-3 py-1.5 rounded-full flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
          Volume Load
        </span>
        <span class="glass text-[11px] text-ml-accent-light px-3 py-1.5 rounded-full flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
          Deteksi Stagnasi
        </span>
        <span class="glass text-[11px] text-ml-accent-light px-3 py-1.5 rounded-full flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          1RM
        </span>
      </div>

      <!-- Auth Glass Card -->
      <div class="glass-strong p-6 gradient-border">

        <!-- Tabs -->
        <div class="flex rounded-xl p-1 mb-6" style="background: rgba(255,255,255,0.04);">
          <button id="tab-login" class="flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all bg-ml-accent text-white" style="box-shadow: 0 0 12px rgba(59,130,246,0.3);" onclick="switchTab('login')">Masuk</button>
          <button id="tab-register" class="flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all text-ml-subtle" onclick="switchTab('register')">Daftar Baru</button>
        </div>

        <!-- Login -->
        <form id="form-login" class="space-y-4">
          <div>
            <label class="text-[11px] text-ml-muted uppercase tracking-wider block mb-1.5">Email</label>
            <input type="email" name="email" placeholder="nama@email.com" required autocomplete="email" class="w-full" />
          </div>
          <div>
            <label class="text-[11px] text-ml-muted uppercase tracking-wider block mb-1.5">Password</label>
            <input type="password" name="password" placeholder="Masukkan password" required autocomplete="current-password" class="w-full" />
          </div>
          <button type="submit" class="btn-primary w-full flex items-center justify-center gap-2" id="btn-login">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
            Masuk
          </button>
        </form>

        <!-- Register -->
        <form id="form-register" class="space-y-4 hidden">
          <div>
            <label class="text-[11px] text-ml-muted uppercase tracking-wider block mb-1.5">Nama Lengkap</label>
            <input type="text" name="nama" placeholder="Nama kamu" required autocomplete="name" class="w-full" />
          </div>
          <div>
            <label class="text-[11px] text-ml-muted uppercase tracking-wider block mb-1.5">Email</label>
            <input type="email" name="email" placeholder="nama@email.com" required autocomplete="email" class="w-full" />
          </div>
          <div>
            <label class="text-[11px] text-ml-muted uppercase tracking-wider block mb-1.5">Password</label>
            <input type="password" name="password" placeholder="Minimal 6 karakter" required minlength="6" autocomplete="new-password" class="w-full" />
          </div>
          <button type="submit" class="btn-primary w-full flex items-center justify-center gap-2" id="btn-register">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
            Buat Akun
          </button>
        </form>

        <div id="error-msg" class="hidden mt-4 p-3 rounded-xl text-sm text-red-400 text-center" style="background: rgba(239,68,68,0.1); border: 0.5px solid rgba(239,68,68,0.2);"></div>
      </div>

      <p class="text-ml-subtle/60 text-[11px] text-center mt-6">MuscleLog v1.0 — Stagnation Detector</p>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.cookie = 'ml_token=; Path=/; Max-Age=0; SameSite=Lax;';

  function switchTab(tab) {
    const loginForm = document.getElementById('form-login');
    const registerForm = document.getElementById('form-register');
    const tabLogin = document.getElementById('tab-login');
    const tabRegister = document.getElementById('tab-register');
    document.getElementById('error-msg').classList.add('hidden');
    if (tab === 'login') {
      loginForm.classList.remove('hidden'); registerForm.classList.add('hidden');
      tabLogin.className = 'flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all bg-ml-accent text-white';
      tabLogin.style.boxShadow = '0 0 12px rgba(59,130,246,0.3)';
      tabRegister.className = 'flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all text-ml-subtle';
      tabRegister.style.boxShadow = 'none';
    } else {
      loginForm.classList.add('hidden'); registerForm.classList.remove('hidden');
      tabRegister.className = 'flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all bg-ml-accent text-white';
      tabRegister.style.boxShadow = '0 0 12px rgba(59,130,246,0.3)';
      tabLogin.className = 'flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all text-ml-subtle';
      tabLogin.style.boxShadow = 'none';
    }
  }

  async function handleAuth(e, action) {
    e.preventDefault();
    const form = e.target;
    const body = Object.fromEntries(new FormData(form));
    const errorMsg = document.getElementById('error-msg');
    const btn = form.querySelector('button[type="submit"]');
    const origHTML = btn.innerHTML;
    btn.innerHTML = 'Memproses...'; btn.disabled = true;
    try {
      const res = await fetch('/api/auth?action=' + action, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      const data = await res.json();
      if (!res.ok) { errorMsg.textContent = data.error || 'Terjadi kesalahan'; errorMsg.classList.remove('hidden'); btn.innerHTML = origHTML; btn.disabled = false; return; }
      window.location.href = '/';
    } catch { errorMsg.textContent = 'Gagal terhubung ke server'; errorMsg.classList.remove('hidden'); btn.innerHTML = origHTML; btn.disabled = false; }
  }

  document.getElementById('form-login').addEventListener('submit', e => handleAuth(e, 'login'));
  document.getElementById('form-register').addEventListener('submit', e => handleAuth(e, 'register'));
</script>
