---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSession } from "@/lib/auth";
import SetLogger from "@/components/islands/SetLogger";

const session = getSession(Astro.request);
if (!session) return Astro.redirect("/login");
---

<AppLayout title="Sesi Baru — MuscleLog" activeNav="log" hideNav>
  <SetLogger client:load userId={session.userId} userName={session.nama} />
</AppLayout>
