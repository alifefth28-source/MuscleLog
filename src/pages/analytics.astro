---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSession } from "@/lib/auth";
import AnalyticsDashboard from "@/components/islands/AnalyticsDashboard";

const session = getSession(Astro.request);
if (!session) return Astro.redirect("/login");
---

<AppLayout title="Analitik — MuscleLog" activeNav="analytics">
  <div class="pt-6 pb-2">
    <h1 class="text-xl font-extrabold">Analitik</h1>
    <p class="text-sm text-ml-subtle">Pantau progres Volume Load & 1RM</p>
  </div>

  <AnalyticsDashboard client:load userId={session.userId} />
</AppLayout>
