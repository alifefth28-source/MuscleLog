---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSession } from "@/lib/auth";
import { getLatestSessionSummary, getUserSessions, getLatestRpeAvg } from "@/lib/db";
import StagnationAlert from "@/components/islands/StagnationAlert";

const session = getSession(Astro.request);
if (!session) return Astro.redirect("/login");

let latestSummary: Awaited<ReturnType<typeof getLatestSessionSummary>> = null;
let allSessions: Awaited<ReturnType<typeof getUserSessions>> = [];
let rpeAvg: number | null = null;

try {
  latestSummary = await getLatestSessionSummary(session.userId);
  allSessions = await getUserSessions(session.userId, 100);
  rpeAvg = await getLatestRpeAvg(session.userId);
} catch (e) { console.error("Dashboard error:", e); }

const closedSessions = allSessions.filter(s => s.isClosed);
const totalSessions = closedSessions.length;
const now = new Date();
const weekStart = new Date(now); weekStart.setDate(now.getDate() - now.getDay()); weekStart.setHours(0,0,0,0);
const sessionsThisWeek = closedSessions.filter(s => { const d = s.tanggal?.toDate ? s.tanggal.toDate() : new Date(); return d >= weekStart; }).length;
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
const sessionsThisMonth = closedSessions.filter(s => { const d = s.tanggal?.toDate ? s.tanggal.toDate() : new Date(); return d >= monthStart; }).length;

let streakDays = 0;
if (closedSessions.length > 0) {
  const dates = closedSessions.map(s => { const d = s.tanggal?.toDate ? s.tanggal.toDate() : new Date(); return new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime(); }).filter((v,i,a) => a.indexOf(v) === i).sort((a,b) => b - a);
  const today = new Date(); today.setHours(0,0,0,0);
  const todayMs = today.getTime(); const oneDay = 86400000;
  for (let i = 0; i < dates.length; i++) {
    const expected = todayMs - (i * oneDay);
    if (dates[i] === expected) { streakDays++; } else if (i === 0 && dates[i] === todayMs - oneDay) { streakDays++; } else { break; }
  }
}

const latestVL = latestSummary ? latestSummary.reduce((s, e) => s + e.totalVolumeLoad, 0) : 0;
const totalMinutesMonth = closedSessions.filter(s => { const d = s.tanggal?.toDate ? s.tanggal.toDate() : new Date(); return d >= monthStart; }).reduce((sum, s) => sum + (s.durasiMenit || 0), 0);
const totalHoursMonth = Math.round(totalMinutesMonth / 60 * 10) / 10;
---

<AppLayout title="Dashboard — MuscleLog" activeNav="home">
  <!-- Header -->
  <div class="pt-6 pb-2">
    <p class="text-ml-muted text-sm">Selamat datang,</p>
    <h1 class="text-2xl font-extrabold text-white">{session.nama}</h1>
    {streakDays > 0 && streakDays <= 2 && (
      <div class="inline-flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full glass-accent">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 2.5z"/></svg>
        <span class="text-xs font-semibold text-ml-accent-light">{streakDays} hari streak</span>
      </div>
    )}
  </div>

  <!-- Rest Day Alert -->
  {streakDays >= 3 && (
    <div class="mt-4 glass p-4 flex items-start gap-3" style="border-color: rgba(245,158,11,0.2); background: rgba(245,158,11,0.06);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <div>
        <p class="text-sm font-bold text-ml-warning">Rest Day Direkomendasikan</p>
        <p class="text-xs text-ml-warning/70 mt-1">{streakDays} hari berturut-turut latihan. Otot perlu 24-48 jam untuk pemulihan.</p>
      </div>
    </div>
  )}

  <!-- Stagnation Alert -->
  <StagnationAlert client:load userId={session.userId} />

  <!-- Stats Row 1 -->
  <div class="grid grid-cols-2 gap-3 mt-5">
    <div class="glass p-4">
      <div class="flex items-center gap-1.5 mb-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <p class="text-[11px] text-ml-muted uppercase tracking-wide">Minggu ini</p>
      </div>
      <p class="text-3xl font-extrabold text-white">{sessionsThisWeek}</p>
      <p class="text-[11px] text-ml-subtle mt-1">{sessionsThisMonth} sesi bulan ini</p>
    </div>
    <div class="glass p-4">
      <div class="flex items-center gap-1.5 mb-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        <p class="text-[11px] text-ml-muted uppercase tracking-wide">Vol Load</p>
      </div>
      <p class="text-3xl font-extrabold text-white">{latestVL > 0 ? (latestVL >= 1000 ? (latestVL / 1000).toFixed(1) + "k" : latestVL.toString()) : "—"}</p>
      {latestVL > 0 && <p class="text-[11px] text-ml-accent-light mt-1">Sesi terakhir</p>}
    </div>
  </div>

  <!-- Stats Row 2 -->
  <div class="grid grid-cols-3 gap-3 mt-3">
    <div class="glass p-3">
      <p class="text-[10px] text-ml-muted uppercase tracking-wide mb-1">RPE</p>
      <p class="text-xl font-extrabold text-ml-accent-light">{rpeAvg !== null ? rpeAvg : "—"}</p>
      {rpeAvg !== null && <p class="text-[10px] text-ml-subtle">RIR: {(10 - rpeAvg).toFixed(1)}</p>}
    </div>
    <div class="glass p-3">
      <p class="text-[10px] text-ml-muted uppercase tracking-wide mb-1">Streak</p>
      <p class="text-xl font-extrabold text-white">{streakDays}<span class="text-[10px] text-ml-subtle ml-0.5">hari</span></p>
    </div>
    <div class="glass p-3">
      <p class="text-[10px] text-ml-muted uppercase tracking-wide mb-1">Durasi</p>
      <p class="text-xl font-extrabold text-white">{totalHoursMonth}<span class="text-[10px] text-ml-subtle ml-0.5">jam</span></p>
      <p class="text-[10px] text-ml-subtle">bulan ini</p>
    </div>
  </div>

  <!-- Sesi Terakhir -->
  {latestSummary && latestSummary.length > 0 && (
    <div class="mt-6">
      <h2 class="section-title">Sesi Terakhir</h2>
      <div class="glass p-3 space-y-0.5">
        {latestSummary.map((ex) => (
          <div class="flex items-center gap-3 py-2 px-1 rounded-lg hover:bg-white/[0.03] transition-colors">
            <div class="w-2 h-2 rounded-full bg-ml-accent flex-shrink-0" style="box-shadow: 0 0 8px rgba(59,130,246,0.4);"></div>
            <span class="text-sm flex-1">{ex.exerciseName}</span>
            <span class="text-sm text-ml-accent-light font-semibold">VL: {ex.totalVolumeLoad.toLocaleString()}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- CTA -->
  <a href="/session/new" class="btn-primary w-full text-center block mt-6 text-base gradient-border">+ Mulai Sesi Latihan</a>

  <!-- Riwayat -->
  {closedSessions.length > 0 && (
    <div class="mt-6">
      <div class="flex items-center justify-between mb-2">
        <h2 class="section-title mb-0">Riwayat</h2>
        <a href="/history" class="text-xs text-ml-accent">Lihat semua</a>
      </div>
      <div class="space-y-2">
        {closedSessions.slice(0, 3).map((s) => (
          <a href={`/session/${s.id}`} class="glass p-3 flex items-center justify-between hover:bg-white/[0.06] transition-colors block">
            <div>
              <p class="text-sm font-semibold">{s.namaSesi}</p>
              <p class="text-xs text-ml-subtle">{s.tanggal?.toDate ? s.tanggal.toDate().toLocaleDateString("id-ID", { weekday: "short", day: "numeric", month: "short", year: "numeric" }) : "—"}</p>
            </div>
            <p class="text-xs text-ml-muted">{s.durasiMenit} mnt</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Onboarding for first-time users -->
  {totalSessions === 0 && (
    <div class="mt-6">
      <!-- Welcome -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl glass-accent mb-4 glow-accent">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.5"><path d="M6.5 6.5h11"/><path d="M6.5 17.5h11"/><path d="M6 2L6 22"/><path d="M18 2L18 22"/><path d="M3 6h3"/><path d="M3 18h3"/><path d="M18 6h3"/><path d="M18 18h3"/><path d="M12 2v20"/></svg>
        </div>
        <h3 class="text-lg font-bold text-white">Selamat datang di MuscleLog!</h3>
        <p class="text-sm text-ml-muted mt-1">3 langkah mudah untuk memulai</p>
      </div>

      <!-- Step 1 -->
      <div class="glass p-4 mb-3">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-sm font-bold text-[#3B82F6]" style="background: rgba(59,130,246,0.12);">1</div>
          <div>
            <h4 class="text-sm font-bold text-white">Buat Sesi Latihan</h4>
            <p class="text-xs text-ml-muted mt-1">Tekan tombol "+ Mulai Sesi Latihan" di bawah. Beri nama sesi (contoh: Push Day, Leg Day) dan pilih tanggal.</p>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="glass p-4 mb-3">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-sm font-bold text-[#3B82F6]" style="background: rgba(59,130,246,0.12);">2</div>
          <div>
            <h4 class="text-sm font-bold text-white">Pilih Gerakan dan Catat Set</h4>
            <p class="text-xs text-ml-muted mt-1">Pilih gerakan yang akan dilatih (Bench Press, Squat, dan lain-lain). Lalu input beban (kg) dan jumlah repetisi untuk setiap set.</p>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="glass p-4 mb-3">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-sm font-bold text-[#3B82F6]" style="background: rgba(59,130,246,0.12);">3</div>
          <div>
            <h4 class="text-sm font-bold text-white">Pantau Progres di Analitik</h4>
            <p class="text-xs text-ml-muted mt-1">Setelah minimal 3 sesi, buka halaman Analitik untuk melihat grafik perkembangan. Sistem otomatis mendeteksi jika latihanmu stagnan dan memberikan saran.</p>
          </div>
        </div>
      </div>

      <!-- What is VL/RPE quick intro -->
      <div class="glass-accent p-4 mt-4">
        <h4 class="text-sm font-bold text-[#60A5FA] mb-2">Istilah yang perlu diketahui</h4>
        <div class="space-y-2 text-xs text-[#60A5FA]/80 leading-relaxed">
          <p><strong class="text-[#60A5FA]">Volume Load (VL)</strong> = Beban x Repetisi. Angka ini menunjukkan total kerja ototmu. Semakin naik dari sesi ke sesi, artinya ada progres.</p>
          <p><strong class="text-[#60A5FA]">RPE</strong> = Skala 1-10 seberapa berat usahamu. RPE 7 artinya "berat tapi masih bisa 3 rep lagi". Targetkan RPE 7-8 untuk pemula.</p>
          <p><strong class="text-[#60A5FA]">1RM</strong> = Prediksi beban maksimal yang bisa diangkat 1 kali. Dihitung otomatis, tidak perlu coba langsung.</p>
        </div>
      </div>
    </div>
  )}
</AppLayout>
