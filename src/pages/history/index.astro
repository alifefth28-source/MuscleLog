---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSession } from "@/lib/auth";
import { getUserSessions } from "@/lib/db";

const session = getSession(Astro.request);
if (!session) return Astro.redirect("/login");

const sessions = await getUserSessions(session.userId, 50);
---

<AppLayout title="Riwayat — MuscleLog" activeNav="log">
  <div class="pt-6 pb-2">
    <h1 class="text-xl font-extrabold">Riwayat Latihan</h1>
    <p class="text-sm text-ml-subtle">{sessions.length} sesi tercatat</p>
  </div>

  <div class="space-y-2 mt-4">
    {sessions.map((s) => (
      <a href={`/session/${s.id}`} class="card-elevated flex items-center justify-between">
        <div>
          <p class="text-sm font-semibold">{s.namaSesi}</p>
          <p class="text-xs text-ml-subtle">
            {s.tanggal?.toDate
              ? s.tanggal.toDate().toLocaleDateString("id-ID", {
                  weekday: "short",
                  day: "numeric",
                  month: "short",
                  year: "numeric",
                })
              : "—"}
          </p>
        </div>
        <div class="text-right">
          {s.isClosed ? (
            <p class="text-xs text-ml-subtle">{s.durasiMenit} mnt</p>
          ) : (
            <span class="badge badge-accent text-[10px]">Aktif</span>
          )}
        </div>
      </a>
    ))}
  </div>

  {sessions.length === 0 && (
    <div class="text-center py-16 text-ml-subtle">
      <svg class="mx-auto mb-3" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <p>Belum ada riwayat latihan.</p>
      <a href="/session/new" class="btn-primary inline-block mt-4">Mulai Sesi Pertama</a>
    </div>
  )}
</AppLayout>
